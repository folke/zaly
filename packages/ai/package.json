{
  "name": "@zaly/ai",
  "version": "0.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "build": "z build",
    "lint": "z lint",
    "models": "bun scripts/fetch-models.ts && bun scripts/build-models.ts",
    "test": "z test"
  },
  "dependencies": {
    "@zaly/shared": "workspace:*"
  },
  "devDependencies": {
    "jsonrepair": "^3.14.0"
  },
  "peerDependencies": {
    "typebox": "^1.2.14"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "jsonrepair": "3.14.0"
  }
}
