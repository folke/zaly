{
  "name": "@zaly/shared",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./detect": {
      "bun": "./src/detect/index.ts",
      "default": "./dist/detect.mjs"
    },
    "./env": {
      "bun": "./src/env.ts",
      "default": "./dist/env.mjs"
    },
    "./image": {
      "bun": "./src/image/index.ts",
      "default": "./dist/image.mjs"
    },
    "./process": {
      "bun": "./src/process/index.ts",
      "default": "./dist/process.mjs"
    },
    "./registry": {
      "bun": "./src/registry.ts",
      "default": "./dist/registry.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./detect": "./dist/detect.mjs",
      "./env": "./dist/env.mjs",
      "./image": "./dist/image.mjs",
      "./process": "./dist/process.mjs",
      "./registry": "./dist/registry.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "z build",
    "lint": "z lint",
    "test": "z test"
  },
  "dependencies": {
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "image-meta": "^0.2.2"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "image-meta": "0.2.2"
  }
}
