{
  "name": "@zaly/shared",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown --cwd ../../ --filter @zaly/shared",
    "check": "oxlint",
    "test": "bun test && vitest -r ../../ --project @zaly/shared run"
  },
  "dependencies": {
    "image-meta": "^0.2.2"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  }
}
