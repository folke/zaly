    "get-east-asian-width": "1.5.0",
    "ignore": "7.0.5",
    "image-meta": "0.2.2",
    "is-fullwidth-code-point": "5.1.0",
    "js-yaml": "5.1.0",
    "picomatch": "4.0.4",
    "shell-quote": "1.8.4",
    "slice-ansi": "9.0.0",
    "string-width": [
      "8.2.0",
      "8.2.1"
    ],
    "strip-ansi": "7.2.0",
    "wrap-ansi": "10.0.0"
  }
}
