{
  "name": "@zaly/shared",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./env": {
      "bun": "./src/env.ts",
      "default": "./dist/env.mjs"
    },
    "./registry": {
      "bun": "./src/registry.ts",
      "default": "./dist/registry.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./env": "./dist/env.mjs",
      "./registry": "./dist/registry.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown --cwd ../../ --filter @zaly/shared",
    "check": "oxlint",
    "test": "bun test && vitest -r ../../ --project @zaly/shared run"
  },
  "dependencies": {
    "image-meta": "^0.2.2",
    "pathe": "^2.0.3"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "pathe": "2.0.3"
  }
}
