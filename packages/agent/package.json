{
  "name": "@zaly/agent",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./session": {
      "bun": "./src/session/index.ts",
      "default": "./dist/session.mjs"
    },
    "./session/claude": {
      "bun": "./src/session/claude.ts",
      "default": "./dist/session/claude.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./session": "./dist/session.mjs",
      "./session/claude": "./dist/session/claude.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "z build",
    "lint": "z lint",
    "test": "z test"
  },
  "dependencies": {
    "@zaly/ai": "workspace:*",
    "@zaly/shared": "workspace:*",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "jsonpath-plus": "^10.4.0",
    "ignore": "^7.0.5",
    "shell-quote": "^1.8.3",
    "@types/shell-quote": "^1.7.5"
  },
  "peerDependencies": {
    "typebox": "^1.1.38"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "ignore": "7.0.5",
    "jsonpath-plus": "10.4.0",
    "shell-quote": "1.8.3"
  }
}
