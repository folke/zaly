{
  "name": "@zaly/agent",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "src/**/*",
    "dist/**/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown --cwd ../../ --filter @zaly/agent",
    "check": "cd ../../; oxlint packages/agent",
    "test": "bun test:node && bun test:bun",
    "test:node": "cd ../../; vitest --project @zaly/agent run",
    "test:bun": "bun test --only-failures"
  },
  "dependencies": {
    "@zaly/ai": "workspace:*"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "publint": "^0.3.18",
    "tsdown": "^0.21.9",
    "typebox": "^1.1.33",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  }
}
