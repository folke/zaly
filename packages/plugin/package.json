{
  "name": "@zaly/plugin",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "dist/**/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "build": "z build",
    "lint": "z lint",
    "test": "z test"
  },
  "dependencies": {
    "@zaly/agent": "workspace:*",
    "@zaly/ai": "workspace:*",
    "@zaly/shared": "workspace:*",
    "@zaly/tui": "workspace:*"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "devDependencies": {
    "jiti": "^2.7.0",
    "typebox": "^1.2.1"
  },
  "inlinedDependencies": {
    "jiti": "2.7.0"
  }
}
