{
  "name": "@zaly/cli",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "bin": {
    "zaly": "./bin/zaly.ts"
  },
  "files": [
    "src/**/*",
    "bin/**/*",
    "dist/**/*"
  ],
  "type": "module",
  "exports": {
    "./main": {
      "bun": "./src/main.ts",
      "default": "./dist/main.mjs"
    },
    "./zaly": {
      "bun": "./bin/zaly.ts",
      "default": "./dist/zaly.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "zaly": "./dist/zaly.mjs"
    },
    "exports": {
      "./main": "./dist/main.mjs",
      "./zaly": "./dist/zaly.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "z build",
    "lint": "z lint",
    "postinstall": "node ./scripts/postinstall.mjs",
    "test": "z test"
  },
  "dependencies": {
    "@zaly/agent": "workspace:*",
    "@zaly/ai": "workspace:*",
    "@zaly/tui": "workspace:*",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@zaly/shared": "workspace:*",
    "citty": "^0.2.2",
    "pathe": "^2.0.3"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "citty": "0.2.2",
    "pathe": "2.0.3"
  },
  "trustedDependencies": [
    "sharp"
  ]
}
