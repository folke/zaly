{
  "name": "@zaly/cli",
  "version": "0.0.3",
  "description": "Hackable terminal coding agent.",
  "keywords": [
    "agent",
    "ai",
    "cli",
    "coding-agent",
    "terminal",
    "tui"
  ],
  "homepage": "https://github.com/folke/zaly/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/folke/zaly/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git",
    "directory": "packages/cli"
  },
  "bin": {
    "zaly": "./bin/zaly.ts"
  },
  "files": [
    "dist/**/*",
    "scripts/postinstall.mjs"
  ],
  "type": "module",
  "exports": {
    "./main": {
      "bun": "./src/main.ts",
      "default": "./dist/main.mjs"
    },
    "./zaly": {
      "bun": "./bin/zaly.ts",
      "default": "./dist/zaly.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "bin": {
      "zaly": "./dist/zaly.mjs"
    },
    "exports": {
      "./main": "./dist/main.mjs",
      "./zaly": "./dist/zaly.mjs",
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "build": "z build",
    "lint": "z lint",
    "postinstall": "node ./scripts/postinstall.mjs",
    "test": "z test"
  },
  "dependencies": {
    "@zaly/agent": "workspace:*",
    "@zaly/ai": "workspace:*",
    "@zaly/config": "workspace:*",
    "@zaly/plugin": "workspace:*",
    "@zaly/shared": "workspace:*",
    "@zaly/tui": "workspace:*",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@zaly/shared": "workspace:*",
    "citty": "^0.2.2",
    "pathe": "^2.0.3",
    "rolldown": "^1.1.5",
    "scule": "^1.3.0"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "citty": "0.2.2",
    "pathe": "2.0.3"
  },
  "trustedDependencies": [
    "sharp"
  ]
}
