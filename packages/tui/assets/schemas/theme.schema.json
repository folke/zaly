            "mdHeading4",
            "mdHeading5",
            "mdHeading6",
            "mdStrong",
            "mdEmphasis",
            "mdStrikethrough",
            "mdCode",
            "mdCodeBlock",
            "mdCodeBlockTitle",
            "mdLink",
            "mdBlockquote",
            "mdList",
            "mdListChecked",
            "mdListUnchecked",
            "mdHr",
            "mdTable",
            "mdTableHeader",
            "inherit"
          ]
        }
      ],
      "description": "A color value. Accepted forms:\n - `#rgb` / `#rrggbb` hex\n - ANSI color names (`red`, `cyan`, `gray`, …)\n - Bright ANSI variants (`brightRed`, `brightBlue`, …)\n - Theme slot keys from `keyof Theme` (`primary`, `muted`, …)\n - `'inherit'` — use the parent's color (renders as no escape)."
    },
