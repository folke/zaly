{
  "name": "@zaly/tui",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "src/**/*",
    "dist/**/*",
    "assets/**/*"
  ],
  "type": "module",
  "imports": {
    "#ansi": {
      "bun": "./src/runtime/ansi.bun.ts",
      "default": "./dist/ansi.node.mjs"
    },
    "#md": {
      "bun": "./src/runtime/md.bun.ts",
      "default": "./dist/md.node.mjs"
    }
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./themes": {
      "bun": "./src/themes/registry.ts",
      "default": "./dist/themes.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./themes": "./dist/themes.mjs",
      "./package.json": "./package.json"
    },
    "imports": {
      "#ansi": {
        "bun": "./dist/ansi.bun.mjs",
        "default": "./dist/ansi.node.mjs"
      },
      "#md": {
        "bun": "./dist/md.bun.mjs",
        "default": "./dist/md.node.mjs"
      }
    }
  },
  "scripts": {
    "bench": "bun bench/run.ts",
    "build": "z build",
    "build:schemas": "bun scripts/schemas.ts",
    "build:themes-1-shiki": "bun scripts/themes-shiki.ts",
    "build:themes-2-tokyonight": "bun scripts/themes-tokyonight.ts",
    "build:themes-3-builtin": "bun scripts/themes-builtin.ts && oxfmt src/themes/builtin.ts",
    "docs:api": "typedoc",
    "docs:build": "bun run docs:api && vitepress build docs",
    "docs:dev": "bun run docs:api && vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "lint": "z lint",
    "test": "z test"
  },
  "dependencies": {
    "@zaly/shared": "workspace:*",
    "diff": "^9.0.0",
    "marked": "^18.0.3",
    "pathe": "^2.0.3",
    "shiki": "^4.0.2",
    "slice-ansi": "^9.0.0",
    "string-width": "^8.2.1",
    "typia": "^12.1.1",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@typia/transform": "^12.1.1",
    "ghostty-web": "^0.4.0",
    "sharp": "^0.34.5"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "ansi-regex": "6.2.2",
    "ansi-styles": "6.2.3",
    "get-east-asian-width": "1.5.0",
    "is-fullwidth-code-point": "5.1.0",
    "pathe": "2.0.3",
    "slice-ansi": "9.0.0",
    "string-width": [
      "8.2.0",
      "8.2.1"
    ],
    "strip-ansi": "7.2.0",
    "wrap-ansi": "10.0.0"
  }
}
