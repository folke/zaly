{
  "name": "@zaly/tui",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "src/**/*",
    "dist/**/*",
    "assets/**/*"
  ],
  "type": "module",
  "imports": {
    "#ansi": {
      "bun": "./src/runtime/ansi.bun.ts",
      "default": "./src/runtime/ansi.node.ts"
    },
    "#md": {
      "bun": "./src/runtime/md.bun.ts",
      "default": "./src/runtime/md.node.ts"
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./themes": "./src/themes/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./themes": "./dist/themes.mjs",
      "./package.json": "./package.json"
    },
    "imports": {
      "#ansi": "./dist/ansi.mjs",
      "#md": "./dist/md.mjs"
    }
  },
  "scripts": {
    "bench": "bun bench/run.ts",
    "build": "tsdown --cwd ../../ --filter @zaly/tui",
    "build:themes": "bun scripts/build-themes.ts",
    "build:shiki-themes": "bun scripts/build-shiki-themes.ts",
    "build:typia": "bun scripts/build-schemas.ts",
    "check": "oxlint",
    "docs:api": "typedoc",
    "docs:dev": "bun run docs:api && vitepress dev docs",
    "docs:build": "bun run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "bun test && vitest -r ../../ --project @zaly/tui run"
  },
  "dependencies": {
    "@zaly/shared": "workspace:*",
    "diff": "^9.0.0",
    "marked": "^18.0.3",
    "pathe": "^2.0.3",
    "shiki": "^4.0.2",
    "slice-ansi": "^9.0.0",
    "string-width": "^8.2.1",
    "typia": "^12.1.1",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@typia/transform": "^12.1.1",
    "ghostty-web": "^0.4.0",
    "sharp": "^0.34.5",
    "type-fest": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "ansi-regex": "6.2.2",
    "ansi-styles": "6.2.3",
    "get-east-asian-width": "1.5.0",
    "is-fullwidth-code-point": "5.1.0",
    "pathe": "2.0.3",
    "slice-ansi": "9.0.0",
    "string-width": [
      "8.2.0",
      "8.2.1"
    ],
    "strip-ansi": "7.2.0",
    "wrap-ansi": "10.0.0"
  },
  "trustedDependencies": [
    "sharp"
  ]
}
