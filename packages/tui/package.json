{
  "name": "@zaly/tui",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "src/**/*",
    "dist/**/*",
    "assets/**/*"
  ],
  "type": "module",
  "imports": {
    "#ansi": {
      "bun": "./src/runtime/ansi.bun.ts",
      "default": "./dist/ansi.node.mjs"
    },
    "#md": {
      "bun": "./src/runtime/md.bun.ts",
      "default": "./dist/md.node.mjs"
    }
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./ansi": {
      "bun": "./src/style/ansi.ts",
      "default": "./dist/ansi.mjs"
    },
    "./logger": {
      "bun": "./src/services/logger.ts",
      "default": "./dist/logger.mjs"
    },
    "./markdown": {
      "bun": "./src/markdown/index.ts",
      "default": "./dist/markdown.mjs"
    },
    "./shiki": {
      "bun": "./src/style/shiki.ts",
      "default": "./dist/shiki.mjs"
    },
    "./style": {
      "bun": "./src/style/index.ts",
      "default": "./dist/style.mjs"
    },
    "./themes": {
      "bun": "./src/themes/registry.ts",
      "default": "./dist/themes.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "imports": {
      "#ansi": {
        "bun": "./dist/ansi.bun.mjs",
        "default": "./dist/ansi.node.mjs"
      },
      "#md": {
        "bun": "./dist/md.bun.mjs",
        "default": "./dist/md.node.mjs"
      }
    },
    "exports": {
      ".": "./dist/index.mjs",
      "./ansi": "./dist/ansi.mjs",
      "./logger": "./dist/logger.mjs",
      "./markdown": "./dist/markdown.mjs",
      "./shiki": "./dist/shiki.mjs",
      "./style": "./dist/style.mjs",
      "./themes": "./dist/themes.mjs",
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "bench": "z bench",
    "build": "z build",
    "build:themes-1-shiki": "bun scripts/themes-shiki.ts",
    "build:themes-2-tokyonight": "bun scripts/themes-tokyonight.ts",
    "build:themes-3-builtin": "bun scripts/themes-builtin.ts && oxfmt src/themes/builtin.ts",
    "docs:api": "typedoc",
    "docs:build": "bun run docs:api && vitepress build docs",
    "docs:dev": "bun run docs:api && vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "lint": "z lint",
    "test": "z test"
  },
  "dependencies": {
    "@zaly/shared": "workspace:*",
    "diff": "^9.0.0",
    "marked": "^18.0.4",
    "pathe": "^2.0.3",
    "shiki": "^4.1.0"
  },
  "devDependencies": {
    "ghostty-web": "^0.4.0",
    "slice-ansi": "^9.0.0",
    "string-width": "^8.2.1",
    "typia": "^12.1.1",
    "wrap-ansi": "^10.0.0"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "typia": "12.1.1"
  }
}
