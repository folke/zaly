{
  "name": "@zaly/tui",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/folke/zaly.git"
  },
  "files": [
    "src/**/*",
    "dist/**/*",
    "assets/**/*"
  ],
  "type": "module",
  "imports": {
    "#runtime": {
      "bun": "./src/runtime.bun.ts",
      "default": "./src/runtime.node.ts"
    }
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./runtime.node": {
      "bun": "./src/runtime.node.ts",
      "default": "./dist/runtime.node.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./runtime.node": "./dist/runtime.node.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "bench": "bun bench/run.ts",
    "build": "tsdown --cwd ../../ --filter @zaly/tui",
    "build:themes": "bun scripts/build-themes.ts",
    "build:typia": "bun scripts/build-schemas.ts",
    "check": "cd ../../; oxlint packages/tui",
    "test": "bun test:node && bun test:bun",
    "test:node": "cd ../../; vitest --project @zaly/tui run",
    "test:bun": "bun test --only-failures"
  },
  "dependencies": {
    "image-meta": "^0.2.2",
    "marked": "^18.0.2",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "slice-ansi": "^9.0.0",
    "string-width": "^8.2.0",
    "typia": "^12.0.2",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@typia/transform": "^12.0.2",
    "ghostty-web": "^0.4.0",
    "mitata": "^1.0.34",
    "publint": "^0.3.18",
    "tsdown": "^0.21.9",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  },
  "inlinedDependencies": {
    "type-fest": "5.5.0"
  },
  "trustedDependencies": []
}
