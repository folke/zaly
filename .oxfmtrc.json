{
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 100,
  "trailingComma": "es5",
  "proseWrap": "preserve",
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": ["packages/*/etc/**/*", "packages/*/assets/**/*", "packages/*/src/**/gen/**/*"],
  // "sortTailwindcss": true,
  "sortImports": {
    "newlinesBetween": false,
    "groups": [
      "type-import",
      ["type-internal", "type-parent", "type-sibling", "type-index"],
      { "newlinesBetween": true },
      ["value-builtin", "value-external"],
      ["value-internal", "value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  }
}
