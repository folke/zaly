{
  "compilerOptions": {
    "lib": ["ESNext"],
    "types": ["@types/bun"],
    "target": "ESNext",
    "module": "nodenext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": false,

    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    // Prefer the `bun` condition when resolving workspace packages so
    // `@zaly/tui` follows the `exports.bun` branch (→ TS source)
    // rather than `exports.default` (→ dist/*.mjs). Keeps go-to-def,
    // find-refs, and rename scoped to real source during development.
    "customConditions": ["bun"],

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": true,

    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "exclude": ["dist"]
}
