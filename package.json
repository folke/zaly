{
  "name": "zaly",
  "version": "0.0.3",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/folke/zaly"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "oxlint",
    "pkg": "bun --workspaces install",
    "fix": "oxlint --fix",
    "rules": "bun ./scripts/oxlint-rules.ts",
    "out": "bun outdated; bun outdated --filter '*'",
    "up": "bun --workspaces update --latest",
    "build": "bun build:assets && tsdown",
    "build:assets": "bun run --sequential --no-exit-on-error --workspaces 'build:*'",
    "test": "bun test --no-env-file && bun vitest",
    "test:live": "bun test live"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/bun": "^1.3.13",
    "@typescript/native-preview": "^7.0.0-dev.20260425.1",
    "mitata": "^1.0.34",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.10",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  }
}
