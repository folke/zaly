{
  "name": "zaly",
  "version": "0.0.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/folke/zaly"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.1",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "@vitest/coverage-v8": "4.1.10",
    "@zaly/dev": "workspace:*",
    "knip": "^6.25.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.4",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "6.0.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitest": "^4.1.10"
  },
  "bugs": {
    "url": "https://github.com/folke/zaly/issues"
  },
  "description": "Hackable terminal coding agent.",
  "engines": {
    "bun": ">=1.2",
    "node": ">=22.11"
  },
  "homepage": "https://zaly.dev",
  "license": "MIT",
  "private": true,
  "scripts": {
    "api": "z api",
    "api:check": "z api --check",
    "build": "z build",
    "fmt": "z fmt",
    "knip": "knip",
    "lint": "z lint",
    "models": "bun run --cwd 'packages/ai' models",
    "out": "bun outdated; bun outdated --filter '*'",
    "pkg": "bun --workspaces install",
    "publish": "z publish",
    "test": "z test --bun",
    "test:live": "LIVE=1 bun test live",
    "up": "bun z update"
  },
  "trustedDependencies": [
    "sharp"
  ],
  "type": "module",
  "workspaces": [
    "packages/*",
    "plugins"
  ]
}
