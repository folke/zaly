{
  "name": "zaly",
  "version": "0.0.3",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/folke/zaly"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "oxlint",
    "fix": "oxlint --fix",
    "rules": "bun ./scripts/oxlint-rules.ts",
    "out": "bun outdated; bun outdated --filter '*'",
    "up": "bun update --latest; cd packages/cli && bun update --latest; cd ../tui && bun update --latest",
    "build": "bun run --filter @zaly/cli build:typia && tsdown",
    "test": "bun test:node && bun test:bun",
    "test:node": "vitest run",
    "test:bun": "bun test --only-failures",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@typescript/native-preview": "^7.0.0-dev.20260417.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsdown": "^0.21.9",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2",
    "node": ">=24"
  }
}

